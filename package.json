{
  "name": "citadel",
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "build": "bun run build:app",
    "build:app": "tauri build",
    "build:web": "tsc && vite build",
    "dev": "bun run dev:app",
    "dev:app": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "dev:web": "vite dev",
    "format": "bun format:web; bun format:backend",
    "format:backend": "cargo fmt --all",
    "format:web": "biome format --write src/",
    "format:check": "biome format src/ && cargo fmt --check --all",
    "lint": "bun lint:web && bun lint:backend",
    "lint:web": "biome lint src/",
    "lint:backend": "cargo clippy --workspace",
    "quality": "bun format:check; bun lint",
    "preview:web": "vite preview",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@faker-js/faker": "^10.5.0",
    "@iconify-json/f7": "^1.2.2",
    "@storybook/addon-links": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tanstack/router-devtools": "^1.167.0",
    "@tanstack/router-vite-plugin": "^1.167.18",
    "@tauri-apps/cli": "^2.11.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.5.1",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "storybook": "^10.4.6",
    "storybook-dark-mode": "^5.0.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "@storybook/addon-docs": "^10.4.6"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "~2.4.3",
    "@types/dompurify": "^3.2.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^2.6.1",
    "tailwind-variants": "^0.1.20",
    "zustand": "^5.0.14"
  }
}
